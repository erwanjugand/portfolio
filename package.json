{
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "type": "module",
  "scripts": {
    "analyze": "nuxt analyze",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "test:unit": "vitest run --silent",
    "test:e2e": "cypress open",
    "check:prettier": "prettier --check .",
    "check:lint": "eslint",
    "check:stylelint": "stylelint **/*.{scss,vue}",
    "check:ts": "vue-tsc --build --noEmit",
    "check:all": "pnpm check:prettier && pnpm check:lint && pnpm check:stylelint && pnpm check:ts",
    "check:ci": "pnpm nuxi prepare && pnpm check:all",
    "fix:prettier": "prettier --log-level warn --write .",
    "fix:lint": "pnpm check:lint --fix",
    "fix:stylelint": "pnpm check:stylelint --fix",
    "fix:svg": "svgo public --recursive --quiet",
    "fix:image": "sh parse-image.sh",
    "fix:all": "pnpm fix:prettier && pnpm fix:lint && pnpm fix:stylelint && pnpm fix:svg"
  },
  "devDependencies": {
    "@erwanjugand/eslint-config": "2.4.0",
